+    extern step_condition_ext_t g_conditions[]; /* weakly referenced, layout unknown */
+    (void)g_conditions; /* avoid unused-warning if not present */
+
+    /* No-op fallback: we at least clear staging */
+    staged_part = staged_step = staged_node = -1;
+    memset(&staged_condition, 0, sizeof(staged_condition));
+}
