+/* Simple staged condition storage (conservative): store single staging area
+ * and commit into the public g_conditions array (if available) or call weak hook.
+ *
+ * This implementation intentionally keeps semantics minimal:
+ * - stage_* just stores values
+ * - commit writes into g_conditions[channel][step] if that symbol exists
+ * - if a stronger project-specific implementation exists, it can provide the
+ *   following weak hooks to integrate:
+ *     void condition_commit_hook(int part, int step, int node, const step_condition_ext_t *out)
+ */
+
+/* weak hooks that higher-level code may override */
+void condition_commit_hook(int part, int step, int node, const step_condition_ext_t *out) __attribute__((weak));
+
+/* Staging area */
+static int staged_part = -1;
+static int staged_step = -1;
+static int staged_node = -1;
+static step_condition_ext_t staged_condition;
+
+void condition_stage_part(int part)
+{
+    staged_part = part;
+}
+
+void condition_stage_step(int step)
+{
+    staged_step = step;
+}
+
+void condition_stage_node(int node)
+{
+    staged_node = node;
+}
+
+/* Fill staged_condition with default/no-op values if needed */
+static void staged_condition_init_if_needed(void)
+{
+    /* If needed: ensure staged_condition members are in known state.
+       We keep this generic — actual structure depends on project's step_condition_ext_t */
+    memset(&staged_condition, 0, sizeof(staged_condition));
+}
+
+void condition_set_current(const step_condition_ext_t *c)
+{
+    staged_condition_init_if_needed();
+    if (c) memcpy(&staged_condition, c, sizeof(staged_condition));
+}
